# ─────────────────────────────────────────────
# Backend — Symfony
# ─────────────────────────────────────────────
backend/vendor/
backend/var/
backend/.env.local
backend/.env.*.local
backend/.env.production

# JWT keys — regenerate with lexik:jwt:generate-keypair
backend/config/jwt/private.pem
backend/config/jwt/public.pem

# Uploaded media files — serve from object storage in production
backend/public/uploads/

# Symfony cache/build artifacts
backend/.php-cs-fixer.cache
backend/.phpunit.result.cache

